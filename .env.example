# Keep mock while developing without Google credentials.
INSPECTION_PROVIDER=mock

# Switch to real Google Search Console URL Inspection API.
# INSPECTION_PROVIDER=gsc
# GSC_LANGUAGE_CODE=en-US

# Production/staging public URL. Use this in Google OAuth redirect URIs.
# APP_BASE_URL=https://index-health.your-domain.com

# Supabase Postgres connection string.
# Use the pooled connection string if Supabase gives you one.
# DATABASE_URL=postgresql://postgres.xxx:password@aws-0-region.pooler.supabase.com:6543/postgres
# DATABASE_SSL=true
# APP_STATE_KEY=production

# Dashboard Google OAuth. With these env vars set, users only see
# "Continue with Google"; they do not need to paste OAuth secrets.
# GOOGLE_OAUTH_CLIENT_ID=your-client-id.apps.googleusercontent.com
# GOOGLE_OAUTH_CLIENT_SECRET=your-client-secret
# GOOGLE_OAUTH_REDIRECT_URI=https://index-health.your-domain.com/auth/google/callback

# Optional service account mode instead of dashboard OAuth.
# GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account.json

# Optional: run dashboard on a different local port.
# PORT=3001
